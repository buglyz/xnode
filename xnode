def test_all():
    """TCPing 所有节点，不需要切换/重启 xray"""
    cfg = load_cfg()
    if not cfg:
        print(f"  {RED}❌ 无配置{R}")
        return {}
    nodes = get_nodes(cfg)
    if not nodes:
        print(f"  {RED}❌ 无节点{R}")
        return {}
    cur = current_tag(cfg)
    latencies = {}

    print(f"  测试 {len(nodes)} 个节点（TCPing）...\n")
    for i, node in enumerate(nodes):
        num = i + 1
        tag = node["tag"]
        host, port = node_addr(node)
        if not host:
            latencies[num] = None
            print(f"  {B}{num}{R}  {tag}  {RED}❌ 无地址{R}")
            continue
        lats = [tcping(host, port) for _ in range(3)]
        valid = [l for l in lats if l is not None]
        avg = sum(valid) / len(valid) if valid else None
        latencies[num] = avg
        proto, addr = node_info(node)
        marker = f" {GREEN}👈{R}" if tag == cur else ""
        print(f"  {B}{num}{R}  {tag}  ({proto} {addr})  {fmt_lat(avg)}{marker}")
        time.sleep(0.2)

    best_num = min(latencies, key=lambda k: latencies[k] if latencies[k] is not None else 999)
    if latencies[best_num] is not None and latencies[best_num] < 999:
        print(f"\n  🏆 最快: {nodes[best_num-1]['tag']}  {fmt_lat(latencies[best_num])}")
    return latencies

def test_all_curl():
    """真连接测试所有节点：逐个切换 + curl 端到端，慢但反映真实代理性能"""
    if not service_active():
        print(f"  {RED}❌ xray 未运行，无法真连接测试{R}")
        return {}
    cfg = load_cfg()
    if not cfg:
        print(f"  {RED}❌ 无配置{R}")
        return {}
    nodes = get_nodes(cfg)
    if not nodes:
        print(f"  {RED}❌ 无节点{R}")
        return {}
    orig = current_tag(cfg)
    latencies = {}

    print(f"  测试 {len(nodes)} 个节点（真连接，逐个切换）...\n")
    for i, node in enumerate(nodes):
        num = i + 1
        tag = node["tag"]
        if tag != current_tag():
            new_out = [node] + [o for o in load_cfg()["outbounds"] if o["tag"] != tag]
            cfg2 = load_cfg()
            cfg2["outbounds"] = new_out
            save_cfg(cfg2)
            restart_xray()
            time.sleep(1)
        lats = [curl_once() for _ in range(3)]
        valid = [l for l in lats if l is not None]
        avg = sum(valid) / len(valid) if valid else None
        latencies[num] = avg
        proto, addr = node_info(node)
        marker = f" {GREEN}👈{R}" if tag == orig else ""
        print(f"  {B}{num}{R}  {tag}  ({proto} {addr})  {fmt_lat(avg)}{marker}")

    # 切回原始节点
    if orig != current_tag():
        cfg2 = load_cfg()
        orig_node = [o for o in cfg2["outbounds"] if o["tag"] == orig]
        rest = [o for o in cfg2["outbounds"] if o["tag"] != orig]
        cfg2["outbounds"] = orig_node + rest
        save_cfg(cfg2)
        restart_xray()
        print(f"\n  已切回 {orig}")

    best_num = min(latencies, key=lambda k: latencies[k] if latencies[k] is not None else 999)
    if latencies[best_num] is not None and latencies[best_num] < 999:
        print(f"\n  🏆 最快: {nodes[best_num-1]['tag']}  {fmt_lat(latencies[best_num])}")
    return latencies

