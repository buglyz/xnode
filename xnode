def direct_switch(num):
    """num 从 1 开始"""
    cfg = load_cfg()
    nodes = get_nodes(cfg)
    idx = num - 1
    if idx < 0 or idx >= len(nodes):
        print(f"❌ 序号 {num} 越界，范围 1-{len(nodes)}")
        sys.exit(1)
    do_switch(num, nodes)
    for i in range(3):
        lat = curl_once()
        print(f"  #{i+1} {fmt_lat(lat)}")
        time.sleep(0.5)

# ── 主入口 ──

def main():
    args = sys.argv[1:]

    if not args:
        if sys.stdin.isatty():
            interactive()
        else:
            cur = current_tag()
            print(f"当前: {cur}")
            cfg = load_cfg()
            nodes = get_nodes(cfg)
            for i, node in enumerate(nodes):
                num = i + 1
                proto, addr = node_info(node)
                marker = " 👈" if node["tag"] == cur else ""
                print(f"  {num}  {node['tag']}  ({proto} {addr}){marker}")
        return

    a = args[0]
    if a == "-t":
        test_current_tcping()
        print()
        test_current_curl()
    elif a == "-T":
        test_all()
    elif a == "-E":
        test_all_curl()
    elif a == "-u":
        sync_sub()
    elif a == "-i":
        install_xray()
    elif a == "-s":
        show_status()
    else:
        try:
            num = int(a)
            direct_switch(num)
        except ValueError:
            print(f"❌ 输入数字序号（从 1 开始）或 -t/-T/-E/-u/-i/-s")
            sys.exit(1)

if __name__ == "__main__":
    main()
