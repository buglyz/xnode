def prompt_scope():
    """选测试后问：当前/所有"""
    print(f"\n  {B}1{R}  当前节点    {B}2{R}  所有节点")
    try:
        c = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None
    if c == "1":
        return "current"
    elif c == "2":
        return "all"
    return None

def interactive():
    while True:
        menu_offset = draw_main_menu()
        try:
            choice = input("\n  > ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not choice:
            continue

        # 0 = 退出
        if choice == "0":
            break

        # 统一数字解析
        try:
            num = int(choice)
        except ValueError:
            print(f"  {RED}❌ 请输入数字{R}")
            time.sleep(1)
            continue

        if not xray_installed():
            if num == 1:
                install_xray()
                input("\n  回车继续...")
            continue

        cfg = load_cfg()
        nodes = get_nodes(cfg) if cfg else []
        node_count = len(nodes)

        # 1~node_count → 切换节点
        if 1 <= num <= node_count:
            do_switch(num, nodes)
            input("\n  回车继续...")
            continue

        test_ping = node_count + 1
        test_curl = node_count + 2
        act_sub = node_count + 3
        act_manage = node_count + 4
        act_status = node_count + 5
        act_restart = node_count + 6
        act_install = node_count + 7

        if num == test_ping:
            scope = prompt_scope()
            if scope == "current":
                test_current_tcping()
            elif scope == "all":
                test_all()
            input("\n  回车继续...")
        elif num == test_curl:
            scope = prompt_scope()
            if scope == "current":
                test_current_curl()
            elif scope == "all":
                test_all_curl()
            input("\n  回车继续...")
        elif num == act_sub:
            sync_sub()
            input("\n  回车继续...")
        elif num == act_manage:
            manage_sub()
            input("\n  回车继续...")
        elif num == act_status:
            show_status()
            input("\n  回车继续...")
        elif num == act_restart:
            print("  重启 xray...")
            restart_xray()
            print(f"  {GREEN}✅ 已重启{R}")
            input("\n  回车继续...")
        elif num == act_install:
            install_xray()
            input("\n  回车继续...")

