#!/usr/bin/env python3
"""xnode — xray 一键管理工具

安装 xray、管理订阅、切换节点、延迟测试，一个脚本全搞定。

用法:
  xnode               交互式主菜单
  xnode 2             直接切到序号 2（从 1 开始）
  xnode -t            测当前节点（TCPing + 真连接）
  xnode -T            TCPing 所有节点（快速，不切换）
  xnode -E            真连接测试所有节点（逐个切换，慢）
  xnode -u            更新订阅
  xnode -i            安装 xray
  xnode -s            查看服务状态
"""

import base64, json, os, platform, re, shutil, socket, subprocess, sys, time
from urllib.parse import urlparse, parse_qs, unquote
from pathlib import Path

# ── 路径配置 ──

XRAY_BIN = "/usr/local/bin/xray"
XRAY_DIR = "/usr/local/etc/xray"
CONFIG = f"{XRAY_DIR}/config.json"
NODES_STATE = f"{XRAY_DIR}/nodes.json"  # 持久化节点序号
GEOIP = "/usr/local/share/xray/geoip.dat"
GEOSITE = "/usr/local/share/xray/geosite.dat"
SYSTEMD_UNIT = "/etc/systemd/system/xray.service"
SUB_ENV = "/etc/xray-sub-sync.env"
SERVICE = "xray"

SOCKS_PORT = 20170
HTTP_PORT = 20171

# ── 颜色 ──

R = "\033[0m"
B = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"

# ── 工具函数 ──

def clear():
    sys.stdout.write("\033[2J\033[H")
    sys.stdout.flush()

def run(cmd, **kw):
    return subprocess.run(cmd, capture_output=True, text=True, **kw)

def run_ok(cmd, **kw):
    return run(cmd, **kw).returncode == 0

def xray_installed():
    return os.path.isfile(XRAY_BIN) and os.access(XRAY_BIN, os.X_OK)

def service_active():
    return run_ok(["systemctl", "is-active", "--quiet", SERVICE])

def load_cfg():
    if not os.path.isfile(CONFIG):
        return None
    with open(CONFIG) as f:
        return json.load(f)

def save_cfg(cfg):
    os.makedirs(os.path.dirname(CONFIG), exist_ok=True)
    tmp = CONFIG + ".tmp"
    with open(tmp, "w") as f:
        json.dump(cfg, f, ensure_ascii=False, indent=2)
    os.replace(tmp, CONFIG)

# ── 持久化节点序号 ──

def load_node_order():
    """从 nodes.json 读取持久化的节点 tag 顺序列表"""
    if os.path.isfile(NODES_STATE):
        try:
            with open(NODES_STATE) as f:
                data = json.load(f)
                return data.get("order", [])
        except Exception:
            pass
    return None

def save_node_order(order):
    """写入持久化节点顺序"""
    os.makedirs(os.path.dirname(NODES_STATE), exist_ok=True)
    tmp = NODES_STATE + ".tmp"
    with open(tmp, "w") as f:
        json.dump({"order": order}, f, ensure_ascii=False, indent=2)
    os.replace(tmp, NODES_STATE)

def get_nodes(cfg=None):
    """返回按持久化顺序排列的代理节点列表，序号从 1 开始。
    已有节点保持原顺序，新节点追加到末尾，消失的节点从顺序中移除。"""
    cfg = cfg or load_cfg()
    if not cfg:
        return []
    # 从 config 提取所有代理节点
    all_tags = {o["tag"]: o for o in cfg.get("outbounds", [])
                if o["tag"] not in ("direct", "block")}

    if not all_tags:
        return []

    # 加载持久化顺序
    saved_order = load_node_order()

    if saved_order is None:
        # 首次：按 tag 排序初始化
        saved_order = sorted(all_tags.keys())
        save_node_order(saved_order)

    # 构建最终顺序：保留已有顺序，追加新节点，移除消失的
    result = []
    seen = set()
    for tag in saved_order:
        if tag in all_tags and tag not in seen:
            result.append(all_tags[tag])
            seen.add(tag)
    # 追加新节点（config 有但 order 里没有的）
    for tag in sorted(all_tags.keys()):
        if tag not in seen:
            result.append(all_tags[tag])
            seen.add(tag)

    # 如果顺序有变化，更新持久化文件
    new_order = [o["tag"] for o in result]
    if new_order != saved_order:
        save_node_order(new_order)

    return result

def refresh_node_order_after_sub(new_tags):
    """订阅更新后合并新节点到持久化顺序：旧的保留位置，新的追加到末尾"""
    saved_order = load_node_order()
    if saved_order is None:
        save_node_order(sorted(new_tags))
        return

    # 已有顺序里只保留还存在的
    existing = set(new_tags)
    updated = [t for t in saved_order if t in existing]
    # 追加新节点
    seen = set(updated)
    for t in sorted(new_tags):
        if t not in seen:
            updated.append(t)
            seen.add(t)
    save_node_order(updated)

def current_tag(cfg=None):
    cfg = cfg or load_cfg()
    if not cfg:
        return None
    for o in cfg.get("outbounds", []):
        if o["tag"] not in ("direct", "block"):
            return o["tag"]
    return None

def node_info(ob):
    proto = ob["protocol"].upper()
    addr = ""
    if "vnext" in ob["settings"]:
        addr = ob["settings"]["vnext"][0]["address"]
    elif "servers" in ob["settings"]:
        addr = ob["settings"]["servers"][0]["address"]
    return proto, addr

def node_addr(ob):
    """从 outbound 提取 (host, port)"""
    if "vnext" in ob["settings"]:
        v = ob["settings"]["vnext"][0]
        return v["address"], v["port"]
    if "servers" in ob["settings"]:
        s = ob["settings"]["servers"][0]
        return s["address"], s["port"]
    return None, None

def tcping(host, port, timeout=5):
    """TCP 握手测延迟，不经过代理、不重启 xray"""
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(timeout)
        start = time.time()
        s.connect((host, int(port)))
        lat = time.time() - start
        s.close()
        return lat
    except Exception:
        return None

def curl_once():
    """经代理 curl 测端到端延迟（仅测当前节点用）"""
    try:
        r = run(["curl", "-sS", "--socks5-hostname", "127.0.0.1:20170",
                 "-o", "/dev/null", "-w", "%{time_total}",
                 "--max-time", "10",
                 f"https://www.google.com/?_={int(time.time()*1000)}"],
                timeout=15)
        s = r.stdout.strip()
        if r.returncode != 0:
            return None
        lat = float(s) if s else None
        # 0.000s 不是真延迟，重试
        if lat is not None and lat < 0.01:
            time.sleep(0.3)
            r2 = run(["curl", "-sS", "--socks5-hostname", "127.0.0.1:20170",
                      "-o", "/dev/null", "-w", "%{time_total}",
                      "--max-time", "10", "-H", "Connection: close",
                      f"https://www.google.com/?_={int(time.time()*1000)}"],
                     timeout=15)
            s2 = r2.stdout.strip()
            if r2.returncode != 0:
                return None
            lat = float(s2) if s2 else None
        return lat
    except Exception:
        return None

def fmt_lat(v):
    if v is None:
        return f"{RED}❌ 超时{R}"
    if v < 1:
        return f"{GREEN}{v:.3f}s{R}"
    if v < 3:
        return f"{YELLOW}{v:.2f}s{R}"
    return f"{RED}{v:.1f}s ⚠️{R}"

def restart_xray():
    run(["systemctl", "reset-failed", SERVICE])
    r = run(["systemctl", "restart", SERVICE])
    if r.returncode != 0:
        print(f"  {RED}❌ restart 失败: {r.stderr.strip()}{R}")
        return False
    for _ in range(10):
        try:
            run(["curl", "-sS", "--socks5-hostname", "127.0.0.1:20170",
                 "-o", "/dev/null", "--max-time", "3",
                 f"https://www.google.com/?_={int(time.time()*1000)}"],
                timeout=5)
            return True
        except Exception:
            time.sleep(0.3)
    return False

def get_sub_url():
    if os.path.isfile(SUB_ENV):
        with open(SUB_ENV) as f:
            for line in f:
                if line.startswith("XRAY_SUB_URL="):
                    return line.split("=", 1)[1].strip().strip("'\"")
    return ""

def set_sub_url(url):
    lines = []
    if os.path.isfile(SUB_ENV):
        with open(SUB_ENV) as f:
            lines = f.readlines()
    found = False
    for i, l in enumerate(lines):
        if l.startswith("XRAY_SUB_URL="):
            lines[i] = f'XRAY_SUB_URL="{url}"\n'
            found = True
            break
    if not found:
        lines.append(f'XRAY_SUB_URL="{url}"\n')
    has_socks = any(l.startswith("XRAY_SOCKS_PORT=") for l in lines)
    has_http = any(l.startswith("XRAY_HTTP_PORT=") for l in lines)
    has_config = any(l.startswith("XRAY_CONFIG=") for l in lines)
    if not has_socks:
        lines.append(f'XRAY_SOCKS_PORT="{SOCKS_PORT}"\n')
    if not has_http:
        lines.append(f'XRAY_HTTP_PORT="{HTTP_PORT}"\n')
    if not has_config:
        lines.append(f'XRAY_CONFIG="{CONFIG}"\n')
    with open(SUB_ENV, "w") as f:
        f.writelines(lines)

# ── 默认配置（直通模式）──

def write_default_config():
    """写入最小默认配置：SOCKS5 + HTTP 直通（无代理节点）。
    安装后端口立即可用，添加订阅后会被覆盖。"""
    os.makedirs(os.path.dirname(CONFIG), exist_ok=True)
    cfg = {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {"tag": "socks", "listen": "127.0.0.1", "port": SOCKS_PORT,
             "protocol": "socks", "settings": {"auth": "noauth", "udp": True},
             "sniffing": {"enabled": True, "destOverride": ["http", "tls"]}},
            {"tag": "http", "listen": "127.0.0.1", "port": HTTP_PORT,
             "protocol": "http", "settings": {},
             "sniffing": {"enabled": True, "destOverride": ["http", "tls"]}},
        ],
        "outbounds": [
            {"tag": "direct", "protocol": "freedom", "settings": {}},
            {"tag": "block", "protocol": "blackhole", "settings": {}},
        ],
        "routing": {
            "domainStrategy": "AsIs",
            "rules": [
                {"type": "field", "outboundTag": "direct", "domain": ["geosite:cn"]},
                {"type": "field", "outboundTag": "direct", "ip": ["geoip:private", "geoip:cn"]},
            ],
        },
    }
    save_cfg(cfg)
    print(f"  {DIM}默认配置已写入（直通模式）{R}")

# ── 安装 ──

def install_xray():
    clear()
    print(f"\n  {B}{CYAN}═══ 安装 xray-core ═══{R}\n")

    if xray_installed():
        v = run([XRAY_BIN, "version"])
        first = v.stdout.split("\n")[0] if v.stdout else "?"
        print(f"  已安装: {first}")
        print(f"  {DIM}路径: {XRAY_BIN}{R}")
        a = input(f"\n  {YELLOW}重新安装? [y/N]{R} ").strip().lower()
        if a != "y":
            return

    arch = platform.machine().lower()
    arch_map = {"x86_64": "amd64", "aarch64": "arm64", "armv7l": "arm32"}
    go_arch = arch_map.get(arch, arch)
    print(f"  架构: {arch} → {go_arch}")

    print("  获取最新版本...")
    r = run(["curl", "-sf", "https://api.github.com/repos/XTLS/Xray-core/releases/latest"])
    if r.returncode != 0:
        print(f"  {RED}❌ 无法获取版本信息{R}")
        return
    try:
        info = json.loads(r.stdout)
        version = info["tag_name"]
        assets = info.get("assets", [])
    except Exception:
        print(f"  {RED}❌ 解析版本信息失败{R}")
        return
    print(f"  最新版本: {version}")

    dl_name = f"Xray-{version[1:]}-linux-{go_arch}.zip"
    dl_url = None
    for a in assets:
        if a["name"] == dl_name:
            dl_url = a["browser_download_url"]
            break
    if not dl_url:
        for a in assets:
            if a["name"].endswith(f"linux-{go_arch}.zip"):
                dl_url = a["browser_download_url"]
                break
    if not dl_url:
        print(f"  {RED}❌ 找不到 {dl_name}{R}")
        return

    tmpdir = "/tmp/xray-install"
    shutil.rmtree(tmpdir, ignore_errors=True)
    os.makedirs(tmpdir, exist_ok=True)
    zipfile = f"{tmpdir}/{dl_name}"

    print(f"  下载中...")
    r = run(["curl", "-L", "-f", "--progress-bar", "-o", zipfile, dl_url], timeout=120)
    if r.returncode != 0:
        print(f"  {RED}❌ 下载失败{R}")
        return

    print("  解压...")
    r = run(["unzip", "-o", zipfile, "-d", tmpdir])
    if r.returncode != 0:
        print(f"  {RED}❌ 解压失败{R}")
        return

    print("  安装文件...")
    os.makedirs(XRAY_DIR, exist_ok=True)
    os.makedirs(os.path.dirname(GEOIP), exist_ok=True)

    xray_src = f"{tmpdir}/xray"
    if not os.path.isfile(xray_src):
        print(f"  {RED}❌ 找不到 xray 二进制{R}")
        return
    shutil.copy2(xray_src, XRAY_BIN)
    os.chmod(XRAY_BIN, 0o755)

    for name, dst in [("geoip.dat", GEOIP), ("geosite.dat", GEOSITE)]:
        src = f"{tmpdir}/{name}"
        if os.path.isfile(src):
            shutil.copy2(src, dst)

    print("  写 systemd 服务...")
    with open(SYSTEMD_UNIT, "w") as f:
        f.write(f"""[Unit]
Description=Xray Service
Documentation=https://github.com/xtls
After=network.target nss-lookup.target

[Service]
User=root
ExecStart={XRAY_BIN} run -config {CONFIG}
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
""")

    run(["systemctl", "daemon-reload"])

    if not os.path.isfile(CONFIG):
        write_default_config()

    v = run([XRAY_BIN, "version"])
    first = v.stdout.split("\n")[0] if v.stdout else "?"
    print(f"\n  {GREEN}✅ 安装完成: {first}{R}")
    print(f"  {DIM}{XRAY_BIN}{R}")

    shutil.rmtree(tmpdir, ignore_errors=True)

    a = input(f"\n  {CYAN}启动 xray? [Y/n]{R} ").strip().lower()
    if a != "n":
        run(["systemctl", "enable", "--now", SERVICE])
        print(f"  {GREEN}✅ xray 已启动{R}")
        print(f"  {DIM}SOCKS5: 127.0.0.1:{SOCKS_PORT}  HTTP: 127.0.0.1:{HTTP_PORT}{R}")
        print(f"  {DIM}当前为直通模式（无代理），添加订阅后自动切换{R}")

# ── 订阅管理 ──

def manage_sub():
    clear()
    print(f"\n  {B}{CYAN}═══ 订阅管理 ═══{R}\n")

    url = get_sub_url()
    if url:
        display = url[:40] + "..." + url[-20:] if len(url) > 60 else url
        print(f"  当前订阅: {display}")
    else:
        print(f"  {YELLOW}未配置订阅{R}")

    print()
    print(f"  1  添加/修改订阅 URL")
    print(f"  2  更新订阅（拉取节点并重启 xray）")
    print(f"  3  删除订阅")
    print(f"  0  返回")
    print()

    choice = input("  > ").strip()
    if choice == "1":
        new_url = input("  订阅 URL: ").strip()
        if new_url:
            set_sub_url(new_url)
            print(f"\n  {GREEN}✅ 已保存{R}")
            a = input(f"  {CYAN}立即更新? [Y/n]{R} ").strip().lower()
            if a != "n":
                sync_sub()
        else:
            print(f"  {RED}URL 不能为空{R}")
    elif choice == "2":
        sync_sub()
    elif choice == "3":
        if os.path.isfile(SUB_ENV):
            os.remove(SUB_ENV)
            print(f"  {GREEN}✅ 已删除{R}")
        else:
            print(f"  无订阅配置")

def sync_sub():
    """拉取订阅、解析、生成 config、合并节点序号、重启 xray"""
    url = get_sub_url()
    if not url:
        print(f"  {RED}❌ 未配置订阅 URL{R}")
        return False

    print(f"  📥 拉取订阅...")

    proxy_args = []
    if service_active():
        proxy_args = ["--proxy", f"socks5://127.0.0.1:{SOCKS_PORT}"]

    r = run(["curl", "-sf", "--connect-timeout", "15", "--max-time", "60"] +
            proxy_args + [url], timeout=90)
    if r.returncode != 0 or not r.stdout.strip():
        print(f"  {RED}❌ 拉取失败{R}")
        return False

    raw = r.stdout.strip()

    try:
        decoded = base64.b64decode(raw + "==").decode("utf-8")
        links = [l.strip() for l in decoded.split("\n") if l.strip()]
    except Exception:
        links = [l.strip() for l in raw.split("\n") if l.strip()]

    print(f"  解码 {len(links)} 条链接")

    outbounds = []
    new_tags = []
    for link in links:
        ob = parse_vless(link) or parse_vmess(link) or parse_ss(link)
        if ob:
            outbounds.append(ob)
            new_tags.append(ob["tag"])
            print(f"    {GREEN}✅{R} {ob['tag']} ({ob['protocol']})")
        else:
            proto = link.split("://")[0] if "://" in link else "?"
            print(f"    {DIM}⏭️{R} {proto}:// (不支持)")

    if not outbounds:
        print(f"  {RED}❌ 没有可用节点{R}")
        return False

    # 合并节点序号：旧的保留位置，新的追加
    refresh_node_order_after_sub(new_tags)

    # 恢复用户选择的默认出站
    saved_order = load_node_order() or []
    # 找当前默认（用户上次选的）
    old_cfg = load_cfg()
    old_default = current_tag(old_cfg) if old_cfg else None

    # 按持久化顺序排 outbounds，保证用户默认出站排第一
    config = generate_config(outbounds)

    # 重新排序 outbounds：默认出站第一，其余按持久化序号
    order_map = {tag: i for i, tag in enumerate(saved_order)}
    proxy_outbounds = [o for o in config["outbounds"]
                       if o["tag"] not in ("direct", "block")]
    rest = [o for o in config["outbounds"]
            if o["tag"] in ("direct", "block")]

    # 默认出站放第一位
    default_node = None
    sorted_proxies = []
    if old_default and any(o["tag"] == old_default for o in proxy_outbounds):
        for o in proxy_outbounds:
            if o["tag"] == old_default:
                default_node = o
            else:
                sorted_proxies.append(o)
    else:
        # 旧默认不在新节点里，取持久化顺序第一个
        if proxy_outbounds:
            sorted_proxies = proxy_outbounds[1:]
            default_node = proxy_outbounds[0]

    config["outbounds"] = ([default_node] + sorted_proxies + rest
                           if default_node else sorted_proxies + rest)

    # 写入
    tmp = CONFIG + ".sync"
    with open(tmp, "w") as f:
        json.dump(config, f, ensure_ascii=False, indent=2)

    r = run([XRAY_BIN, "run", "-test", "-format", "json", "-config", tmp])
    if r.returncode != 0:
        print(f"  {RED}❌ 配置验证失败{R}")
        os.remove(tmp)
        return False

    os.replace(tmp, CONFIG)

    # 统计变化
    old_tags = set(o["tag"] for o in (old_cfg or {}).get("outbounds", [])
                   if o["tag"] not in ("direct", "block"))
    new_tag_set = set(new_tags)
    added = new_tag_set - old_tags
    removed = old_tags - new_tag_set

    print(f"  {GREEN}✅ 配置已更新 ({len(outbounds)} 个节点){R}")
    if added:
        print(f"  {CYAN}  新增: {', '.join(sorted(added))}{R}")
    if removed:
        print(f"  {YELLOW}  移除: {', '.join(sorted(removed))}{R}")

    restart_xray()
    print(f"  {GREEN}✅ xray 已重启{R}")
    return True

# ── 协议解析 ──

def parse_vless(link):
    if not link.startswith("vless://"):
        return None
    u = urlparse(link)
    params = parse_qs(u.query)
    uuid = u.username
    address = u.hostname
    port = int(u.port or 443)
    name = unquote(u.fragment) if u.fragment else f"{address}:{port}"
    security = params.get("security", ["none"])[0]
    sni = params.get("sni", [""])[0]
    flow = params.get("flow", [""])[0]
    fp = params.get("fp", [""])[0]
    pbk = params.get("pbk", [""])[0]
    sid = params.get("sid", [""])[0]
    net = params.get("type", ["tcp"])[0]

    outbound = {
        "tag": name, "protocol": "vless",
        "settings": {"vnext": [{"address": address, "port": port,
                    "users": [{"id": uuid, "encryption": "none", "flow": flow}]}]},
        "streamSettings": {"network": net, "security": security}
    }
    if security == "reality":
        outbound["streamSettings"]["realitySettings"] = {
            "serverName": sni, "fingerprint": fp,
            "publicKey": pbk, "shortId": sid}
    elif security == "tls":
        outbound["streamSettings"]["tlsSettings"] = {
            "serverName": sni, "fingerprint": fp}
    return outbound

def parse_vmess(link):
    if not link.startswith("vmess://"):
        return None
    try:
        b64 = link[8:]
        d = json.loads(base64.b64decode(b64 + "==").decode("utf-8"))
        outbound = {
            "tag": d.get("ps", f"{d['add']}:{d['port']}"),
            "protocol": "vmess",
            "settings": {"vnext": [{"address": d["add"], "port": int(d["port"]),
                        "users": [{"id": d["id"], "alterId": int(d.get("aid", 0)),
                                   "security": d.get("scy", "auto")}]}]},
            "streamSettings": {"network": d.get("net", "tcp")}
        }
        if d.get("net") == "ws":
            outbound["streamSettings"]["wsSettings"] = {
                "path": d.get("path", "/"),
                "headers": {"Host": d.get("host", "")} if d.get("host") else {}}
        if d.get("tls") == "tls":
            outbound["streamSettings"]["security"] = "tls"
            outbound["streamSettings"]["tlsSettings"] = {
                "serverName": d.get("sni", d.get("host", ""))}
        return outbound
    except Exception:
        return None

def parse_ss(link):
    if not link.startswith("ss://"):
        return None
    try:
        rest = link[5:]
        name = ""
        if "#" in rest:
            rest, name = rest.rsplit("#", 1)
            name = unquote(name)
        if "?" in rest:
            rest = rest.split("?")[0]
        if "@" in rest:
            userinfo, hostport = rest.rsplit("@", 1)
            if ":" in userinfo:
                method, password = userinfo.split(":", 1)
            else:
                decoded = base64.b64decode(userinfo + "==").decode("utf-8")
                method, password = decoded.split(":", 1)
            host, port = hostport.rsplit(":", 1)
            return {"tag": name or f"{host}:{port}", "protocol": "shadowsocks",
                    "settings": {"servers": [{"address": host, "port": int(port),
                                "password": password, "method": method}]}}
    except Exception:
        return None
    return None

def generate_config(outbounds):
    all_out = list(outbounds) + [
        {"tag": "direct", "protocol": "freedom", "settings": {}},
        {"tag": "block", "protocol": "blackhole", "settings": {}},
    ]
    return {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {"tag": "socks", "listen": "127.0.0.1", "port": SOCKS_PORT,
             "protocol": "socks", "settings": {"auth": "noauth", "udp": True},
             "sniffing": {"enabled": True, "destOverride": ["http", "tls"]}},
            {"tag": "http", "listen": "127.0.0.1", "port": HTTP_PORT,
             "protocol": "http", "settings": {},
             "sniffing": {"enabled": True, "destOverride": ["http", "tls"]}},
        ],
        "outbounds": all_out,
        "routing": {
            "domainStrategy": "AsIs",
            "rules": [
                {"type": "field", "outboundTag": "direct", "domain": ["geosite:cn"]},
                {"type": "field", "outboundTag": "direct", "ip": ["geoip:private", "geoip:cn"]},
            ],
        },
    }

# ── 节点切换 ──

def do_switch(idx, nodes):
    """idx 从 1 开始"""
    real_idx = idx - 1
    if real_idx < 0 or real_idx >= len(nodes):
        print(f"  {RED}❌ 序号 {idx} 越界，范围 1-{len(nodes)}{R}")
        return
    target = nodes[real_idx]["tag"]
    cfg = load_cfg()
    cur = current_tag(cfg)
    if target == cur:
        print(f"  当前已是 {target}")
        return
    new_out = [nodes[real_idx]] + [o for o in cfg["outbounds"] if o["tag"] != target]
    cfg["outbounds"] = new_out
    save_cfg(cfg)
    print(f"  🔀 {cur} → {target}")
    ok = restart_xray()
    print(f"  {'✅' if ok else '⚠️'} xray 已重启{'（端口就绪）' if ok else '（端口未验证）'}")

